static K_MUTEX_DEFINE(zrpc_{{ channel.name | lower }}_user_data_mutex{{ n }});
#endif

	{% endfor %}

static struct k_mutex *zrpc_{{ channel.name | lower }}_user_data_locks[] = {
	{% for n in range(64) %}
#if {{ n }} < (1 << CONFIG_ZRPC_USER_DATA_BUCKET_SHIFT)
	[{{ n }}u] = &zrpc_{{channel.name | lower}}_user_data_mutex{{ n }},
#endif

	{% endfor %}
};


/**
 * @brief Lock user data bucket corresponding to @p tag.
 *
 * @param tag Tag of the RPC whose user data is to be locked.
 *
 * @retval 0      Bucket locked.
 * @retval -errno An error occurred.
 */
static inline int zrpc_{{ channel.name | lower }}_user_data_lock(zrpc_tag tag)
{
	uint_fast8_t const bucket =
		tag & ((1 << CONFIG_ZRPC_USER_DATA_BUCKET_SHIFT) - 1u);
	return k_mutex_lock(zrpc_{{ channel.name | lower }}_user_data_locks[bucket], K_MSEC(5000));
}


/**
 * @brief Unlock user data bucket corresponding to @p tag.
 *
 * @param tag Tag of the RPC whose user data is to be unlocked.
 */
static inline void zrpc_{{ channel.name | lower }}_user_data_unlock(zrpc_tag tag)
{
	uint_fast8_t const bucket =
		tag & ((1 << CONFIG_ZRPC_USER_DATA_BUCKET_SHIFT) - 1u);
	k_mutex_unlock(zrpc_{{ channel.name | lower }}_user_data_locks[bucket]);
}

