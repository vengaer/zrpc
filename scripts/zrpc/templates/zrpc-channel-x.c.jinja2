{% if rpc.want_reply %}

/**
 * @brief Encode RPC response.
 *
 * @param[in] ret RPC return code.
	{% for param in rpc.out_parameters %}
 * @param[in] {{ param.name | lower }} RPC out parameter {{ param.name }}
	{% endfor %}
 *
 * @retval 0      Message successfully populated.
 * @retval -errno Message population failed.
 */
	{% if rpc.out_parameters | length %}
static int zrpc_{{ channel.name | lower }}_{{ rpc.name | lower }}_encode_reply(struct zrpc_msghdr const *reqhdr,
		struct zrpc_msghdr *rsphdr, size_t rspsz, int rc,
		{{ rpc.out_parameters | map(attribute="c_decl") | join(", ") }}{% if rpc.size_parameters | length %}, {% endif %}{{ rpc.size_parameters | map(attribute="c_decl") | join(", ") }})
	{% else %}
static int zrpc_{{ channel.name | lower }}_{{ rpc.name | lower }}_encode_reply(struct zrpc_msghdr const *reqhdr,
		struct zrpc_msghdr *rsphdr, size_t rspsz, int rc)
	{% endif %}
{
	int ret = 0;
	zrpc_tag tag;
	struct zrpc_tlvb tlvb;

	zrpc_tlvb_init(&tlvb, rspsz - sizeof(*rsphdr), rsphdr->attrs);

	tag = ZRPC_{{ channel.name | upper }}_{{ rpc.name | upper }}_FIX_PARAM_RET;
	ret = zrpc_tlvb_put_u32(&tlvb, tag, (uint32_t)rc);
