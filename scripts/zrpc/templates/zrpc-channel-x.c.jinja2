 * @retval 0        Message successfully decoded.
 * @retval -EPROTO  Peer implements a different RPC protocol.
 * @retval -ENODATA At least one attribute is missing.
 */
static inline int zrpc_{{ channel.name | lower }}_{{ rpc.name | lower }}_decode_request(struct zrpc_msghdr *restrict msghdr, struct zrpc_attr **attrs, size_t nattrs)
{
	size_t n;
	struct zrpc_tlvb tlvb;

	if (unlikely(msghdr->crc != ZRPC_{{ channel.name | upper }}_{{ rpc.name | upper }}_CRC))
		return -EPROTO;

	zrpc_tlvb_init(&tlvb, msghdr->len, msghdr->attrs);
	zrpc_tlvb_skip(&tlvb, msghdr->len);
	n = zrpc_tlvb_map(&tlvb, attrs, nattrs);
